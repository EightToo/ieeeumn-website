---
import CommonLayout from "/src/ui/CommonLayout.astro";

const frontmatter = {
  title: "Page not found",
};
---

<CommonLayout frontmatter={frontmatter}>
  <article>
    <div
      style={{
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "center",
        height: "72svh",
      }}
    >
      <div style="margin: 1em 0;">
        <p style="margin: 0; text-align: center;">404: Page not found</p>
        <p style="margin: 0; text-align: center;">
          <small>Let us know if we broke a link somewhere!</small>
        </p>
      </div>
    </div>
  </article>
</CommonLayout>

---
import MarkdownLayout from "/src/ui/MarkdownLayout.astro";
import { Content, frontmatter } from "/content/about-us.md";
import { Content as EventCommittee } from "/content/committees/event.md";
import { Content as OutreachCommittee } from "/content/committees/outreach.md";
import { Content as TechCommittee } from "/content/committees/tech.md";
import { Content as CurrentOfficers } from "/content/officers/current.md";
import { Content as PreviousOfficers } from "/content/officers/previous.md";
---

<MarkdownLayout frontmatter={frontmatter}>
